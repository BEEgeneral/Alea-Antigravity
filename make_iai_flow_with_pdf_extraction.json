{
  "name": "AleaSignature - Email + PDF + IA",
  "flow": [
    {
      "id": 1,
      "module": "email:TriggerNewEmail",
      "version": 7,
      "parameters": {
        "account": 5628520,
        "folder": "INBOX",
        "criteria": "UNSEEN",
        "markSeen": false,
        "maxResults": 10
      },
      "mapper": {
        "id": "{{1.id}}",
        "from": "{{1.from}}",
        "subject": "{{1.subject}}",
        "text": "{{1.text}}"
      },
      "metadata": {
        "designer": { "x": 0, "y": 0 }
      }
    },
    {
      "id": 2,
      "module": "email:GetEmailContent",
      "version": 2,
      "parameters": {
        "account": 5628520,
        "emailId": "{{1.id}}"
      },
      "mapper": {
        "attachments": "{{1.attachments}}"
      },
      "metadata": {
        "designer": { "x": 150, "y": 0 }
      }
    },
    {
      "id": 3,
      "module": "tools:Iterator",
      "version": 2,
      "parameters": {
        "array": "{{2.attachments}}"
      },
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      }
    },
    {
      "id": 4,
      "module": "http:DownloadFile",
      "version": 1,
      "parameters": {
        "url": "{{3.url}}"
      },
      "metadata": {
        "designer": { "x": 450, "y": 0 }
      }
    },
    {
      "id": 5,
      "module": "pdf:ConvertPDF",
      "version": 1,
      "parameters": {
        "account": null,
        "input_format": "pdf",
        "output_format": "txt"
      },
      "mapper": {
        "file": "{{4.data}}"
      },
      "metadata": {
        "designer": { "x": 600, "y": 0 }
      }
    },
    {
      "id": 6,
      "module": "tools:TextAggregator",
      "version": 1,
      "parameters": {
        "separator": "\n\n--- --- ---\n\n",
        "array": "{{5.text}}",
        "filter_empty_values": true
      },
      "metadata": {
        "designer": { "x": 750, "y": 0 }
      }
    },
    {
      "id": 7,
      "module": "http:MakeRequest",
      "version": 4,
      "parameters": {
        "url": "https://www.aleasignature.com/api/webhook/email",
        "method": "POST",
        "authenticationType": "noAuth",
        "contentType": "json",
        "inputMethod": "jsonString"
      },
      "filter": {
        "name": "Filtrar correos válidos",
        "conditions": [
          [
            { "a": "{{1.from.address}}", "b": "noreply", "o": "text:notcontain" },
            { "a": "{{1.from.address}}", "b": "no-reply", "o": "text:notcontain" },
            { "a": "{{1.from.address}}", "b": "newsletter", "o": "text:notcontain" }
          ]
        ]
      },
      "mapper": {
        "headers": [
          { "name": "Content-Type", "value": "application/json" }
        ],
        "jsonStringBodyContent": "{\"from\":\"{{1.from.address}}\",\"subject\":\"{{1.subject}}\",\"text\":\"{{1.text}}\",\"attachments\":{{2.attachments}},\"attachment_text\":\"{{6.text}}\"}"
      },
      "metadata": {
        "designer": { "x": 900, "y": 0 }
      }
    }
  ],
  "metadata": {
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true
    },
    "zone": "eu1.make.com"
  }
}
